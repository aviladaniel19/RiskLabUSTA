# ─────────────────────────────────────────────
# RiskLab — Variables de Entorno BACKEND
# ─────────────────────────────────────────────
# Copia este archivo como .env:
#   Windows: copy .env.example .env
#   Linux:   cp .env.example .env
#
# NUNCA subas el archivo .env a Git.
# ─────────────────────────────────────────────

# FRED API (OBLIGATORIA)
# Obtén tu clave gratis en:
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=tu_clave_fred_aqui

# APIs opcionales
ALPHA_VANTAGE_KEY=
FINNHUB_KEY=

# Parámetros del modelo
VAR_CONFIDENCE_DEFAULT=0.95
MONTECARLO_N_SIM=10000
GARCH_WINDOW=252
BENCHMARK_TICKER=^GSPC
FRED_RF_SERIE=DGS3MO

# Servidor
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
