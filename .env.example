# =====================================================================
# .env.example — RiskLab USTA
# =====================================================================
# 
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Completa tus API keys en el archivo .env
#   3. NUNCA comitas el archivo .env a GitHub (ya está en .gitignore)
#
# NOTAS:
#   - FRED API: Regístrate gratis en https://fred.stlouisfed.org/
#   - Otros servicios son opcionales; déjalos vacíos si no los usas
#
# =====================================================================

# ── APIs Financieras Externas ──────────────────────────
# FRED (Federal Reserve Economic Data) — Requerido para tasa libre de riesgo
FRED_API_KEY=tu_clave_fred_aqui

# Opcional: Alpha Vantage (datos de bolsa adicionales)
ALPHA_VANTAGE_KEY=

# Opcional: Finnhub (noticias y data empresarial)
FINNHUB_KEY=

# ── Parámetros de Riesgo (valores por defecto) ──────────
# Nivel de confianza para VaR (0.95 = 95%)
VAR_CONFIDENCE_DEFAULT=0.95

# Número de simulaciones Montecarlo
MONTECARLO_N_SIM=10000

# Ventana histórica para GARCH (en días de trading)
GARCH_WINDOW=252

# Ticker del índice de referencia (benchmark)
BENCHMARK_TICKER=^GSPC

# Serie FRED para tasa libre de riesgo (T-Bill 3 meses)
FRED_RF_SERIE=DGS3MO

# ── Servidor ────────────────────────────────────────────
# HOST del backend (0.0.0.0 = accesible desde cualquier interfaz)
BACKEND_HOST=0.0.0.0

# Puerto del backend
BACKEND_PORT=8000

# ── CORS ────────────────────────────────────────────────
# URLs permitidas para solicitudes CORS (en desarrollo: *)
# En producción, restringir a: http://localhost:8501
CORS_ORIGINS=*
